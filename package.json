{
  "name": "P2",
  "private": true,
  "scripts": {
    "start": "npm --prefix Backend start",
    "dev": "npm --prefix Backend run dev",
    "generate:data": "npm --prefix Backend run generate:data",
    "install:backend": "npm --prefix Backend install",
    "test:unit": "jest tests/unit --runInBand",
    "test:e2e": "cypress run --spec \"tests/e2e/**/*.cy.js\"",
    "test:quality": "jest --runInBand --testRegex \"tests/quality/TC013-RNF3-usabilidade\\.js$\"",
    "test:quality:compat": "cypress run --spec \"tests/quality/TC015-RNF5-compatibilidade.cy.js\"",
    "test:resilience": "jest tests/resilience --runInBand",
    "test:performance": "node tests/performance/run-performance.js"
  },
  "devDependencies": {
    "cypress": "^13.15.0",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "k6": "^0.0.0",
    "lighthouse": "^12.2.0",
    "supertest": "^7.1.1"
  }
}
